 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RISS School Event Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .event-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .event-card:hover { transform: translateY(-4px); box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen pb-20">

    <nav class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-black text-blue-600 tracking-tighter">RISS HUB.</h1>
            <div id="live-clock" class="text-xs font-mono text-slate-400 hidden md:block"></div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 pt-12">
        <header class="mb-12">
            <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">What's happening?</h2>
            <p class="text-slate-500 text-lg max-w-2xl">Your central platform for school activities. Information is organized and updated in real-time.</p>
        </header>

        <div class="relative mb-16">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="text-slate-400 text-xl">🔍</span>
            </div>
            <input type="text" id="eventSearch" onkeyup="filterEvents()" 
                placeholder="Search by event name, category, or keyword..." 
                class="w-full p-5 pl-14 rounded-2xl border-none bg-white shadow-xl shadow-slate-200/50 focus:ring-4 focus:ring-blue-100 outline-none transition-all text-lg">
        </div>

        <div class="space-y-16">
            <section>
                <div class="flex items-center space-x-3 mb-8">
                    <span class="flex h-3 w-3 rounded-full bg-green-500 animate-ping"></span>
                    <h3 class="text-xl font-bold tracking-tight">Upcoming Activities</h3>
                </div>
                <div id="upcoming-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    </div>
            </section>

            <section>
                <div class="flex items-center space-x-3 mb-8 opacity-50">
                    <span class="h-3 w-3 rounded-full bg-slate-300"></span>
                    <h3 class="text-xl font-bold tracking-tight">Archive</h3>
                </div>
                <div id="past-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 opacity-60 grayscale-[0.5]">
                    </div>
            </section>
        </div>
    </main>

    <script>
        let allEvents = [];

        // 1. Fetch data from your GitHub JSON file
        async function fetchEvents() {
            try {
                // This looks for 'events.json' in your repository
                const response = await fetch('events.json');
                allEvents = await response.json();
                renderEvents(allEvents);
            } catch (error) {
                console.error("Data not found. Waiting for bridge...");
                document.getElementById('upcoming-list').innerHTML = `
                    <div class="col-span-full py-10 text-center text-slate-400 border-2 border-dashed border-slate-200 rounded-2xl">
                        Waiting for first data sync from Excel...
                    </div>`;
            }
        }

        // 2. Render logic: Separates Upcoming from Past automatically
        function renderEvents(data) {
            const upcomingList = document.getElementById('upcoming-list');
            const pastList = document.getElementById('past-list');
            const today = new Date().toISOString().split('T')[0];

            upcomingList.innerHTML = '';
            pastList.innerHTML = '';

            // Sort by date (Soonest first)
            data.sort((a, b) => new Date(a.date) - new Date(b.date));

            data.forEach(event => {
                const isPast = event.date < today;
                const card = `
                    <div class="event-card bg-white p-7 rounded-3xl border border-slate-100 shadow-sm flex flex-col h-full">
                        <div class="flex justify-between items-start mb-5">
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-[10px] font-black uppercase tracking-widest rounded-lg">${event.category || 'General'}</span>
                            <span class="text-slate-400 text-xs font-bold font-mono uppercase">${event.date}</span>
                        </div>
                        <h4 class="text-xl font-bold text-slate-900 mb-3 leading-tight">${event.title}</h4>
                        <p class="text-slate-500 text-sm leading-relaxed mb-8 flex-grow">${event.description || ''}</p>
                        <div class="pt-5 border-t border-slate-50 flex justify-between items-center">
                            <span class="text-[10px] font-black ${isPast ? 'text-slate-300' : 'text-blue-500'} uppercase tracking-tighter">
                                ${isPast ? 'Completed' : 'Happening Soon'}
                            </span>
                        </div>
                    </div>
                `;

                if (isPast) {
                    pastList.innerHTML += card;
                } else {
                    upcomingList.innerHTML += card;
                }
            });
        }

        // 3. Search Bar logic
        function filterEvents() {
            const query = document.getElementById('eventSearch').value.toLowerCase();
            const filtered = allEvents.filter(e => 
                e.title.toLowerCase().includes(query) || 
                (e.category && e.category.toLowerCase().includes(query)) ||
                (e.description && e.description.toLowerCase().includes(query))
            );
            renderEvents(filtered);
        }

        // Clock & Initial Load
        setInterval(() => {
            const now = new Date();
            document.getElementById('live-clock').innerText = now.toLocaleTimeString();
        }, 1000);

        fetchEvents();
    </script>
</body>
</html>
