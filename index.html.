<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RISS School Event Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .event-card { transition: all 0.3s ease; }
        .event-card:hover { transform: translateY(-4px); box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen pb-20">

    <nav class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-black text-blue-600 tracking-tighter">RISS HUB.</h1>
            <div id="live-clock" class="text-xs font-mono text-slate-400"></div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 pt-12">
        <header class="mb-12">
            <h2 class="text-4xl font-extrabold tracking-tight mb-4 text-slate-900">What's happening?</h2>
            <p class="text-slate-500 text-lg">Connected live to the School Event Forms.</p>
        </header>

        <div id="event-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="col-span-full py-20 text-center text-slate-400 animate-pulse">
                Syncing with school database...
            </div>
        </div>
    </main>

    <script>
        async function loadEvents() {
            const container = document.getElementById('event-container');
            try {
                // Fetching the file Power Automate creates
                const response = await fetch('events.json?t=' + new Date().getTime());
                if (!response.ok) throw new Error("Data file not found");
                
                const data = await response.json();
                container.innerHTML = ''; // Clear loading message

                if (data.length === 0) {
                    container.innerHTML = '<div class="col-span-full text-center p-10 bg-white rounded-2xl border-2 border-dashed">No events found. Submit the Microsoft Form to see them here!</div>';
                    return;
                }

                data.forEach(event => {
                    // This creates the card using the keys from your Power Automate 'Select' box
                    const card = document.createElement('div');
                    card.className = "event-card bg-white p-7 rounded-3xl border border-slate-100 shadow-sm flex flex-col h-full";
                    
                    card.innerHTML = `
                        <div class="flex justify-between items-start mb-5">
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-[10px] font-black uppercase tracking-widest rounded-lg">
                                ${event.category || 'Activity'}
                            </span>
                            <div class="text-right">
                                <p class="text-slate-400 text-xs font-bold font-mono">${event.date || 'TBD'}</p>
                            </div>
                        </div>
                        <h4 class="text-xl font-bold text-slate-900 mb-3">${event.title || 'New Event'}</h4>
                        <p class="text-slate-500 text-sm mb-8 flex-grow">${event.description || ''}</p>
                        <div class="pt-5 border-t border-slate-50">
                            <span class="text-[10px] font-black text-blue-500 uppercase">Live from Forms</span>
                        </div>
                    `;
                    container.appendChild(card);
                });

            } catch (error) {
                container.innerHTML = `
                    <div class="col-span-full p-10 bg-red-50 text-red-600 rounded-2xl border border-red-100 text-center">
                        <strong>Connection Error:</strong> Could not find 'events.json'. <br>
                        Check if the file exists in your GitHub repository.
                    </div>`;
            }
        }

        // Live Clock
        setInterval(() => {
            document.getElementById('live-clock').innerText = new Date().toLocaleTimeString();
        }, 1000);

        // Run the fetch
        loadEvents();
    </script>
</body>
</html>
