<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RISS School Events Dashboard</title>
    <style>
        /* This makes your events look like clean cards */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; padding: 20px; }
        h1 { color: #2c3e50; text-align: center; }
        #event-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; max-width: 1200px; margin: 0 auto; }
        .event-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-left: 5px solid #3498db; }
        .event-card h3 { margin-top: 0; color: #2980b9; text-transform: capitalize; }
        .event-card p { color: #7f8c8d; font-size: 0.9rem; margin: 5px 0; }
        .category-tag { background: #e1f0fa; color: #3498db; padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; }
        .no-events { text-align: center; color: #95a5a6; grid-column: 1 / -1; }
    </style>
</head>
<body>

    <h1>School Activities & Events</h1>

    <div id="event-container">
        <p class="no-events">Loading latest events...</p>
    </div>

    <script>
        // 1. Point this to your JSON file name
        const jsonFile = 'events.json';

        async function loadEvents() {
            try {
                // 2. Fetch the data with a "cache-buster" to ensure it's always fresh
                const response = await fetch(`${jsonFile}?t=${new Date().getTime()}`);
                const events = await response.json();
                
                const container = document.getElementById('event-container');
                container.innerHTML = ""; // Clear the loading message

                if (events.length === 0) {
                    container.innerHTML = "<p class='no-events'>No upcoming events scheduled.</p>";
                    return;
                }

                // 3. Loop through your Power Automate data and build the cards
                events.forEach(event => {
                    const card = document.createElement('div');
                    card.className = 'event-card';
                    
                    // Make sure these names (title, category, date) match your 'Select' box labels!
                    card.innerHTML = `
                        <span class="category-tag">${event.category || 'General'}</span>
                        <h3>${event.title || 'Untitled Event'}</h3>
                        <p><strong>Date:</strong> ${event.date || 'TBD'}</p>
                        <p>${event.description || ''}</p>
                    `;
                    container.appendChild(card);
                });

            } catch (error) {
                console.error("Error loading the events bridge:", error);
                document.getElementById('event-container').innerHTML = 
                    "<p class='no-events'>Unable to load events at this time.</p>";
            }
        }

        // Run the function when the page loads
        loadEvents();
    </script>
</body>
</html>
